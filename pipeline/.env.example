# CosmediLoans SEO pipeline — copy to .env and fill in values.
# Do NOT commit the real .env.

# Google Sheets IDs (create 2 sheets, copy IDs from URLs)
SHEET_ID=your_data_sheet_id_here
SHEET_ID_ALERTS=your_alerts_sheet_id_here

# Discord webhook (optional — leave blank to skip alerts)
DISCORD_WEBHOOK_URL=
DISCORD_CHANNEL_ID=

# Site config — CosmediLoans
SITE_URL=https://www.cosmediloans.com.au
SITE_DOMAIN=cosmediloans.com.au
GSC_PROPERTY=sc-domain:cosmediloans.com.au
GA4_PROPERTY_ID=your_ga4_property_id_here
